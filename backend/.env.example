# Core backend settings
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
DATABASE_NAME=digital_points

# Security
SECRET_KEY=change-this-to-a-long-random-secret
SECRET_KEY_PREVIOUS=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# URLs
BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# MongoDB SRV DNS fallback (optional)
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# Rate limits
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_FORGOT_PASSWORD=5/minute
RATE_LIMIT_RESET_PASSWORD=5/minute
RATE_LIMIT_CONTACT=10/minute
RATE_LIMIT_BOOKING=15/minute

# Email
RESEND_API_KEY=
MAIL_FROM=noreply@digitalpoints.com
MAIL_FROM_NAME=Digital Points Admin
ADMIN_CONTACT_EMAIL=
